import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        double valor, gorjeta;

        System.out.print("Digite o valor gasto: ");
        valor = sc.nextDouble();

        gorjeta = valor * 0.10;

        System.out.println("Valor da gorjeta: R$ " + gorjeta);

        sc.close();
    }
}
